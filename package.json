{
  "name": "@banshee.com/iso7813Parser",
  "version": "1.0.0",
  "description": "ISO/IEC 7813 magnetic stripe card data parser using Chevrotain",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "magstripe",
    "magnetic-stripe",
    "iso-7813",
    "iso7813",
    "chevrotain",
    "parser"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "chevrotain": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}